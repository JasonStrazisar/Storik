{
  "name": "storik",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @storik/api --filter @storik/web dev",
    "dev:api": "pnpm --filter @storik/api dev",
    "dev:web": "pnpm --filter @storik/web dev",
    "build": "pnpm --filter @storik/web build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter e2e exec playwright test",
    "test:e2e:ui": "pnpm --filter e2e exec playwright test --ui"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
