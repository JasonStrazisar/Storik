{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Storik",
  "version": "0.1.0",
  "identifier": "com.storik.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @storik/web dev",
    "beforeBuildCommand": "pnpm --filter @storik/web build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Storik",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
